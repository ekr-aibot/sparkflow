#!/usr/bin/env bash
# Fired after `git rebase` (including `git pull --rebase`).
# Only act for the rebase command, not amend.
if [[ "${1:-}" != "rebase" ]]; then
  exit 0
fi

# ORIG_HEAD is the branch tip before the rebase, stored as a git ref
# (not an environment variable), so we resolve it via `git rev-parse`
# rather than `${ORIG_HEAD:-}`.
export SPARKFLOW_DIFF_OLD="$(git rev-parse --verify ORIG_HEAD 2>/dev/null || echo '')"
export SPARKFLOW_DIFF_NEW="$(git rev-parse HEAD)"
exec "$(dirname "$0")/_run-build.sh"
